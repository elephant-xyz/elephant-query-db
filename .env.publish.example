# .env.publish.example
#
# Copy this file to .env.local on the EC2 instance and fill in real values.
# Real values live in the vault:
#   ~/ObsidianVault/Projects/Elephant/Credentials/filebase-oracle-open-data.md
#   ~/ObsidianVault/Projects/Elephant/Credentials/neo-open-data-neon-db.md
#
# DO NOT commit a file containing real secrets — .env.local is in .gitignore.
#
# Alternatively, export these as shell env vars before running the publish
# commands (the scripts read from process.env directly).

# Neon query DB — unpooled connection string (ep-mute-leaf, aws-us-east-1)
# Source: vault Credentials/neo-open-data-neon-db.md
DATABASE_URL=postgresql://USER:PASSWORD@ep-mute-leaf-XXXXXXXX.us-east-1.aws.neon.tech/neondb?sslmode=require

# Filebase S3-compatible storage
# Source: vault Credentials/filebase-oracle-open-data.md
S3_ACCESS_KEY_ID=YOUR_FILEBASE_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=YOUR_FILEBASE_SECRET_ACCESS_KEY
S3_BUCKET=elephant-oracle-open-data
S3_ENDPOINT=https://s3.filebase.io

# Filebase IPNS (required for mutable pointer; without these the IPNS update
# step is skipped but the upload still completes)
# Source: vault Credentials/filebase-oracle-open-data.md
FILEBASE_API_TOKEN=YOUR_FILEBASE_API_TOKEN
FILEBASE_IPNS_LABEL=oracle-open-data-lee
